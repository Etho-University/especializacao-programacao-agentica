%% ETHAGT90 — Capstone: C4 Container (nível 2)
flowchart TB
    subgraph DC["Docker Compose"]
        direction TB
        RT["Agent Runtime<br/>(LangGraph)"]
        EB["Event Bus<br/>(NATS)"]
        WE["Workflow Engine<br/>(Temporal)"]
        MCPS["MCP Servers<br/>(arxiv, github, confluence)"]
        PG[("Postgres<br/>checkpointer + semântica")]
        VDB[("Qdrant<br/>episódica")]
        KG[("Neo4j<br/>knowledge graph")]
        OBS["Observability<br/>(Phoenix)"]
        GR["Guardrails"]
        OPA["OPA<br/>(policy)"]

        RT <--> EB
        RT <--> WE
        RT <--> MCPS
        RT <--> PG
        RT <--> VDB
        RT <--> KG
        RT -.traces.-> OBS
        RT -.calls.-> GR
        GR -.check.-> OPA
    end

    User["Usuário"] --> RT

    classDef rt fill:#fce7f3,stroke:#be185d,stroke-width:2px,color:#000
    classDef in fill:#dbeafe,stroke:#1e40af,color:#000
    classDef db fill:#fed7aa,stroke:#c2410c,color:#000
    classDef cr fill:#dcfce7,stroke:#15803d,color:#000
    classDef us fill:#fef3c7,stroke:#b45309,color:#000
    class RT rt
    class EB,WE,MCPS in
    class PG,VDB,KG db
    class OBS,GR,OPA cr
    class User us
