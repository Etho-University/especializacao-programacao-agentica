%% ETHAGT03 — Composição típica: Routing → Parallelization → Evaluator-Optimizer
flowchart TB
    T([ticket]) --> R{"Routing<br/>(classificar)"}
    R -- "técnico" --> P["Parallelization<br/>(3 workers em fontes)"]
    R -- "geral" --> Simples["Resposta direta"]
    R -- "reembolso" --> Chain["Prompt Chaining<br/>+ HITL"]
    
    P --> WA["worker KB"]
    P --> WB["worker web"]
    P --> WC["worker tickets"]
    WA --> EO{"Evaluator-Optimizer<br/>(sintetizar + criticar)"}
    WB --> EO
    WC --> EO
    EO -- "refina" --> P
    EO -- "ok" --> Out([resposta])
    Simples --> Out
    Chain --> Out

    classDef rt fill:#fce7f3,stroke:#be185d,color:#000
    classDef par fill:#dbeafe,stroke:#1e40af,color:#000
    classDef ev fill:#fed7aa,stroke:#c2410c,color:#000
    classDef other fill:#e9d5ff,stroke:#7e22ce,color:#000
    classDef term fill:#dcfce7,stroke:#15803d,color:#000
    class R rt
    class P,WA,WB,WC par
    class EO ev
    class Simples,Chain other
    class T,Out term
