%% ETHAGT90 — Capstone: Topologia multi-agente
flowchart TB
    Top["Supervisor Geral<br/>(top-level)"]
    Top --> Orc["Orchestrator<br/>(delegação dinâmica)"]
    Orc --> W1["researcher_arxiv"]
    Orc --> W2["researcher_github"]
    Orc --> W3["researcher_kb"]
    W1 -.resultados.-> Syn["Synthesizer"]
    W2 -.resultados.-> Syn
    W3 -.resultados.-> Syn
    Syn --> EO["Evaluator-Optimizer<br/>(loop de refino)"]
    EO -- "precisa mais" --> Orc
    EO -- "ok" --> Wri["Writer"]
    Wri --> Pub["Publisher"]

    classDef top fill:#fce7f3,stroke:#be185d,stroke-width:2px,color:#000
    classDef orc fill:#fed7aa,stroke:#c2410c,color:#000
    classDef wk fill:#dbeafe,stroke:#1e40af,color:#000
    classDef syn fill:#fef3c7,stroke:#b45309,color:#000
    classDef eo fill:#e9d5ff,stroke:#7e22ce,color:#000
    class Top top
    class Orc orc
    class W1,W2,W3 wk
    class Syn syn
    class EO,Wri,Pub eo
